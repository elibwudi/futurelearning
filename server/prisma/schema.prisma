// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           String   @id
  username     String?  @unique
  name         String
  passwordHash String?
  salt         String?
  role         String   @default("student")
  isAnonymous  Boolean  @default(false)

  courses     Course[]
  progress    Progress[]
  permissions CoursePermission[]

  @@map("users")
}

model Course {
  id          String   @id
  title       String
  description String?
  rawText     String?
  graphData   Json?
  status      String   @default("draft")
  authorId    String
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  progress    Progress[]
  permissions CoursePermission[]
  cache       ContentCache[]

  @@index([authorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("courses")
}

model Progress {
  id        Int      @id @default(autoincrement())
  userId    String
  courseId  String
  data      Json?
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("progress")
}

model CoursePermission {
  id              Int      @id @default(autoincrement())
  courseId        String
  userId          String
  permissionLevel String   @default("member")
  grantedBy       String?
  grantedAt       DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("course_permissions")
}

model ContentCache {
  id        Int      @id @default(autoincrement())
  courseId  String
  nodeId    String
  type      String
  data      String?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, nodeId, type])
  @@index([courseId, nodeId, type])
  @@map("content_cache")
}

model Settings {
  id            Int     @id @default(1)
  provider      String  @default("deepseek")
  deepseekApiKey String?
  deepseekModel  String?
  zhipuApiKey   String?
  zhipuModel    String?
  openaiBaseUrl String?
  openaiApiKey  String?
  openaiModel   String?
  qwenApiKey    String?
  qwenModel     String?
  geminiApiKey  String?
  geminiModel   String?

  @@map("settings")
}
